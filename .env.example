# 环境变量模板

# 复制此文件为 .env 并填入真实值:
# cp .env.example .env

# ── AWS (H0 hackathon requirement) ──
# 获取方式: AWS Console → IAM → Users → chemspectra-agent → Security credentials → Create access key
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DYNAMODB_TABLE=chemspectra-sessions

# ── Qwen API (Alibaba Cloud) ──
# 获取方式: https://modelstudio.console.aliyun.com → API-KEY 管理
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen3.7-max

# ── FTIR.fun API ──
# 获取方式: http://127.0.0.1:18080 或联系管理员
FTIRFUN_API_KEY=your-ftirfun-api-key
FTIRFUN_API_URL=http://127.0.0.1:18080

# ── Server ──
PORT=8080
